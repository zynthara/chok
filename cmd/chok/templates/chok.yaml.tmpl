# {{.Name}} — chok v2 configuration.
#
# This file drives BOTH runtime behaviour and assembly:
#   * every module section present here is linked into the binary —
#     `chok sync` regenerates chok_modules_gen.go from this file;
#   * `enabled: true/false` inside a section is the runtime switch.
# After adding or removing a section, rerun `chok sync` (or `make sync`).
#
# Every leaf is overridable via environment:
#   {{.NameUpper}}_HTTP_ADDR, {{.NameUpper}}_LOG_LEVEL, {{.NameUpper}}_DB_SQLITE_PATH, ...

log:
  level: info        # debug | info | warn | error (hot-reloadable: SIGHUP or config watch)
  format: json       # json | text

http:
  addr: ":8080"

db:
  driver: sqlite     # sqlite | mysql | postgres
  migrate: auto      # auto (dev) | versioned (prod — see migrations/) | off
  sqlite:
    path: {{.Name}}.db

health:
  path: /healthz     # plus /livez and /readyz

metrics:
  path: /metrics     # Prometheus

swagger:
  title: "{{.Name}} API"   # UI + spec at /swagger

debug:
  enabled: false     # /componentz topology view — flip on when debugging

account:
  # Dev-only key generated by `chok init` — long-lived deployments set
  # {{.NameUpper}}_ACCOUNT_SIGNING_KEY instead of committing a secret.
  signing_key: "{{.SigningKey}}"
  # OAuth providers are explicit opt-in; enabling one here and running
  # `chok sync` links and registers it:
  # providers:
  #   google:
  #     enabled: true
  #     client_id: "..."
  #     client_secret: "..."
  #     redirect_url: "https://app.example.com/auth/google/callback"

# More batteries — add a section, run `chok sync`, done:
#   redis:     { addr: "127.0.0.1:6379" }
#   cache:     { memory: { enabled: true } }
#   scheduler: {}
#   audit:     { enabled: true }
#   authz:     {}
#   tracing:   { enabled: true, exporter: stdout }
